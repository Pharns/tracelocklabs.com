---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';

const WEBHOOK_URL = import.meta.env.PUBLIC_N8N_WEBHOOK_URL || '';
---

<Base
  title="Contact"
  description="Contact TraceLock Labs for research partnership inquiries, SBIR/STTR collaboration, and technology evaluation."
>
  <Header slot="header" />

  <Hero
    highlight="Contact"
    title="Research Partnership Inquiries"
    subtitle="TraceLock Labs welcomes inquiries from research partners, universities, government innovation programs, and technology evaluators."
    showCta={false}
  />

  <section class="section">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          <!-- Form -->
          <div>
            <h2 class="text-xl font-heading font-bold text-slate-100 mb-6">Send an Inquiry</h2>
            <form id="contact-form" class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-navy-800 border border-navy-700 rounded-lg text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:outline-none transition-colors"
                  placeholder="Your name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-navy-800 border border-navy-700 rounded-lg text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:outline-none transition-colors"
                  placeholder="you@organization.com"
                />
              </div>

              <div>
                <label for="organization" class="block text-sm font-medium text-slate-300 mb-2">Organization</label>
                <input
                  type="text"
                  id="organization"
                  name="organization"
                  class="w-full px-4 py-3 bg-navy-800 border border-navy-700 rounded-lg text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:outline-none transition-colors"
                  placeholder="University, agency, or company"
                />
              </div>

              <div>
                <label for="inquiry_type" class="block text-sm font-medium text-slate-300 mb-2">Inquiry Type</label>
                <select
                  id="inquiry_type"
                  name="inquiry_type"
                  class="w-full px-4 py-3 bg-navy-800 border border-navy-700 rounded-lg text-slate-200 focus:border-amber-500 focus:outline-none transition-colors"
                >
                  <option value="">Select type</option>
                  <option value="research_partnership">Research Partnership</option>
                  <option value="sbir_sttr">SBIR / STTR Collaboration</option>
                  <option value="technology_evaluation">Technology Evaluation</option>
                  <option value="academic_collaboration">Academic Collaboration</option>
                  <option value="general">General Inquiry</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-3 bg-navy-800 border border-navy-700 rounded-lg text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:outline-none transition-colors resize-none"
                  placeholder="Describe your research interest or inquiry..."
                ></textarea>
              </div>

              <button type="submit" class="btn btn-primary w-full">
                Submit Inquiry
              </button>

              <div id="form-status" class="hidden text-sm text-center py-2 rounded"></div>
            </form>
          </div>

          <!-- Contact Info -->
          <div>
            <h2 class="text-xl font-heading font-bold text-slate-100 mb-6">Direct Contact</h2>
            <div class="space-y-6">
              <div class="card">
                <h3 class="font-heading font-semibold text-slate-100 mb-2">Email</h3>
                <a href="mailto:lab@tracelocklabs.com" class="text-amber-500 hover:text-amber-400 text-sm transition-colors">
                  lab@tracelocklabs.com
                </a>
              </div>

              <div class="card">
                <h3 class="font-heading font-semibold text-slate-100 mb-2">Response Time</h3>
                <p class="text-slate-400 text-sm">Research inquiries are typically reviewed within 3-5 business days.</p>
              </div>

              <div class="card">
                <h3 class="font-heading font-semibold text-slate-100 mb-2">For Consulting Inquiries</h3>
                <p class="text-slate-400 text-sm">
                  For security consulting and implementation services, contact <a href="https://aamcyber.com/contact" target="_blank" rel="noopener noreferrer">AAM Cyber</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WEBHOOK_URL }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = {
      source: 'tracelocklabs',
      name: formData.get('name'),
      email: formData.get('email'),
      organization: formData.get('organization'),
      inquiry_type: formData.get('inquiry_type'),
      message: formData.get('message'),
      timestamp: new Date().toISOString(),
    };

    if (!WEBHOOK_URL) {
      status.textContent = 'Please email lab@tracelocklabs.com directly.';
      status.className = 'text-sm text-center py-2 rounded text-amber-500';
      return;
    }

    try {
      const response = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        status.textContent = 'Inquiry submitted. We will review your message shortly.';
        status.className = 'text-sm text-center py-2 rounded text-teal-400';
        form.reset();
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      status.textContent = 'Submission error. Please email lab@tracelocklabs.com directly.';
      status.className = 'text-sm text-center py-2 rounded text-amber-500';
    }
  });
</script>
