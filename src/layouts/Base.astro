---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "TraceLock Labs is an applied research laboratory focused on distributed wireless detection systems, sensor architectures, and RF situational awareness.",
  ogImage = "/images/og-default.png"
} = Astro.props;

const siteUrl = "https://tracelocklabs.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Primary Meta Tags -->
    <title>{title} | TraceLock Labs</title>
    <meta name="title" content={`${title} | TraceLock Labs`} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | TraceLock Labs`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={`${title} | TraceLock Labs`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Schema.org Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ResearchOrganization",
        "name": "TraceLock Labs",
        "url": "https://tracelocklabs.com",
        "description": "Applied research laboratory focused on distributed wireless detection systems and sensor architectures.",
        "founder": {
          "@type": "Person",
          "name": "Pharns Genece"
        },
        "areaServed": "United States",
        "knowsAbout": ["Wireless Detection Systems", "RF Situational Awareness", "Distributed Sensor Networks", "AI-Assisted RF Classification"]
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-navy-950 focus:rounded focus:font-medium">
      Skip to main content
    </a>
    <slot name="header" />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
