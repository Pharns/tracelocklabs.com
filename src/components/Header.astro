---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/technology', label: 'Technology' },
  { href: '/research', label: 'Research' },
  { href: '/programs', label: 'Programs' },
  { href: '/roadmap', label: 'Roadmap' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-navy-950/95 backdrop-blur-sm border-b border-navy-800">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="TraceLock Labs - Home">
        <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-amber-400 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="text-slate-100 font-heading font-semibold text-lg">TraceLock Labs</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors ${
              (item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href))
                ? 'text-amber-500'
                : 'text-slate-300 hover:text-amber-400'
            }`}
            aria-current={(item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href)) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
        <a href="/contact" class="btn btn-primary text-sm">
          Partner With Us
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="md:hidden p-2 text-slate-300 hover:text-amber-500 transition-colors"
        aria-label="Toggle menu"
        id="mobile-menu-btn"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden hidden pt-4 pb-2 border-t border-navy-800 mt-4" id="mobile-menu">
      <div class="flex flex-col gap-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors py-2 ${
              (item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href))
                ? 'text-amber-500'
                : 'text-slate-300 hover:text-amber-400'
            }`}
            aria-current={(item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href)) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
        <a href="/contact" class="btn btn-primary text-sm w-full mt-2">
          Partner With Us
        </a>
      </div>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
