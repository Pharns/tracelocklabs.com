---
const currentYear = new Date().getFullYear();

const footerLinks = {
  technology: [
    { href: '/technology', label: 'Overview' },
    { href: '/research', label: 'Research' },
    { href: '/roadmap', label: 'Roadmap' },
  ],
  programs: [
    { href: '/programs', label: 'SBIR / STTR' },
    { href: '/contact', label: 'Research Partnerships' },
    { href: 'https://aamcyber.com/sdos', label: 'SDOS Architecture', external: true },
    { href: 'https://aamcyber.com', label: 'AAM Cyber', external: true },
  ],
  legal: [
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/terms', label: 'Terms of Service' },
    { href: '/contact', label: 'Contact' },
  ],
};
---

<footer class="bg-navy-900 border-t border-navy-800">
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-amber-400 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-navy-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-slate-100 font-heading font-semibold text-lg">TraceLock Labs</span>
        </a>
        <p class="text-slate-400 text-sm max-w-md mb-4">
          Applied research laboratory focused on distributed wireless detection systems and sensor architectures.
        </p>
      </div>

      <!-- Technology -->
      <div>
        <h4 class="text-slate-100 font-heading font-semibold mb-4">Technology</h4>
        <ul class="space-y-2">
          {footerLinks.technology.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 text-sm hover:text-amber-500 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h4 class="text-slate-100 font-heading font-semibold mb-4">Programs</h4>
        <ul class="space-y-2">
          {footerLinks.programs.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-400 text-sm hover:text-amber-500 transition-colors"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}{link.external && ' ↗'}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-slate-100 font-heading font-semibold mb-4">Legal</h4>
        <ul class="space-y-2">
          {footerLinks.legal.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 text-sm hover:text-amber-500 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-navy-800 mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">
        &copy; {currentYear} TraceLock Labs, LLC. All rights reserved.
      </p>
    </div>
  </div>
</footer>
