---
interface Props {
  title: string;
  subtitle?: string;
  highlight?: string;
  showCta?: boolean;
}

const { title, subtitle, highlight, showCta = true } = Astro.props;
---

<section class="section relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950 opacity-50"></div>
  <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-gradient-to-bl from-amber-500/5 to-transparent"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl">
      {highlight && (
        <span class="inline-block text-amber-500 text-sm font-medium tracking-wider uppercase mb-4">
          {highlight}
        </span>
      )}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-slate-100 mb-6 leading-tight">
        <slot name="title">
          {title}
        </slot>
      </h1>
      {subtitle && (
        <p class="text-lg md:text-xl text-slate-400 mb-8 leading-relaxed">
          {subtitle}
        </p>
      )}
      <slot name="content" />
      {showCta && (
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href="/contact" class="btn btn-primary">
            Partner With Us
          </a>
          <a href="/technology" class="btn btn-secondary">
            Explore Technology
          </a>
        </div>
      )}
    </div>
  </div>
</section>
